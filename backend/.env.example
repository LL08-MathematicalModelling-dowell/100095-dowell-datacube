# =============================================================================
# Datacube backend – copy to .env and fill in real values.
# Docker Compose loads: env_file: ./backend/.env
# =============================================================================

# Django
SECRET_KEY=change-me-use-long-random-string-in-production
# DJANGO_SETTINGS_MODULE=project.settings.development

# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=datacube_metadata
MONGODB_COLLECTION=metadata
AUTH_DB_NAME=datacube_auth
FILE_STORAGE_DB_NAME=datacube_files

# --- OTP ---
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Server-side pepper used to hash OTPs at rest. Use a long random string (32+ chars).
OTP_PEPPER=replace-me-with-a-long-random-string

# --- Resend (transactional email) ---
# Sandbox From (works without domain verification):
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=DataCube
RESEND_API_KEY=your_resend_api_key
# If RESEND_API_KEY is empty, set ALLOW_STDOUT_EMAIL=true to log OTP codes in the server log.
# ALLOW_STDOUT_EMAIL=true

# OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PRO_PRICE_ID=
FREE_PRICE_ID=

# Demo playground
DEMO_LOGIN_EMAIL=samanta@dowellresearch.se
DEMO_PLAYGROUND_SECRET=change-me-for-demo-html-access

# Celery (optional override)
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
