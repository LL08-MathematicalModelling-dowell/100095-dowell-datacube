# Copy to config/backend.env on the VPS (never commit). Django / Celery production secrets.

SECRET_KEY=change-me
MONGODB_URI=mongodb+srv://user:pass@cluster.example/datacube
MONGODB_DATABASE=datacube_metadata
MONGODB_COLLECTION=metadata
DATACUBE_V2_AUTH_DB=datacube_auth
FILE_STORAGE_DB_NAME=datacube_files

# Optional: Redis URL if not using the compose redis service
# CELERY_BROKER_URL=redis://redis:6379/0

# See backend/project/settings/common.py and datacube_documentation.md for OAuth, email, Stripe, etc.
