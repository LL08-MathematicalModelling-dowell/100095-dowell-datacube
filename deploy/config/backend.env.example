# Copy to config/backend.env on the VPS (never commit).
# Loaded by backend + celery_worker (see deploy/docker-compose.yml).
# DJANGO_SETTINGS_MODULE is set in compose — do not set it here.

# =============================================================================
# Required — app will not start without these
# =============================================================================
SECRET_KEY=replace-with-long-random-string
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=datacube_V2_metadata
MONGODB_COLLECTION=metadata_collection
AUTH_DB_NAME=datacube_V2_auth
FILE_STORAGE_DB_NAME=datacube_V2_db_files

# =============================================================================
# Email / OTP — Gmail SMTP (recommended for production)
# =============================================================================
OTP_PEPPER=replace-with-long-random-pepper
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=datacube002@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-gmail-app-password
DEFAULT_FROM_EMAIL=datacube002@gmail.com
EMAIL_FROM_NAME=DataCube
# ALLOW_STDOUT_EMAIL=false

# =============================================================================
# OAuth — server-side token exchange (optional)
# Frontend VITE_* OAuth ids are set in GitHub Actions, not here.
# =============================================================================
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# =============================================================================
# Stripe (optional)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FREE_PRICE_ID=
PRO_PRICE_ID=

# =============================================================================
# Other optional
# =============================================================================
# DEMO_PLAYGROUND_SECRET=
# DEMO_AUTO_ENSURE_USER=false
# ANALYTICS_TTL_DAYS_TELEMETRY=90

# =============================================================================
# Not used by current settings — do NOT copy from old .env files
# =============================================================================
# DATABASE_URL          → use MONGODB_URI
# DATABASE              → use MONGODB_DATABASE
# COLLECTION            → use MONGODB_COLLECTION
# DEBUG                 → hardcoded in production.py / development.py
# ALLOWED_HOSTS         → hardcoded in production.py (edit file if domain changes)
# MY_BASE_URL           → use VITE_API_BASE in GitHub Actions (frontend build)
# STRIPE_PUBLISHABLE_KEY→ frontend-only if needed; backend uses STRIPE_SECRET_KEY
# REDIS_*               → Celery uses redis://redis:6379/0 from production.py + compose
